# Copy this file to `.env` and adjust as needed.
# The app runs fully offline with seeded data — no external services required.

# Prisma / SQLite (development)
DATABASE_URL="file:./dev.db"

# Optional: FastAPI prediction microservice (see ml-service/). If unset or
# offline, the app still works — forecast features degrade gracefully.
ML_SERVICE_URL="http://localhost:8000"
